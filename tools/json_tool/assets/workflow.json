{
  "version": "1.0",
  "workflow": "json-tool",
  "description": "Minimal workflow router for the bundled validation-first JSON contract surface.",
  "start": "J0_route",
  "nodes": [
    {
      "id": "J0_route",
      "phase": "JSON_TOOL",
      "action": "route_by_input_kind",
      "outputs": [
        "input_kind",
        "target_contract_ref",
        "requested_operations"
      ],
      "guards": {
        "unstructured": {
          "when": "input_kind == external_ds",
          "goto": "J1_extract"
        },
        "structured": {
          "when": "input_kind == json_instance",
          "goto": "J2_validate"
        }
      }
    },
    {
      "id": "J1_extract",
      "phase": "JSON_TOOL",
      "action": "extract_candidate_envelope",
      "outputs": [
        "candidate_envelope"
      ],
      "next": [
        "J2_validate"
      ]
    },
    {
      "id": "J2_validate",
      "phase": "JSON_TOOL",
      "action": "validate_contract",
      "uses_script": "scripts/validate_json_contract.py",
      "notes": [
        "Use the bundled validator to emit validation_report_ref.",
        "When a single file is validated and output paths are provided, the validator can also materialize accepted_json_ref."
      ],
      "outputs": [
        "accepted_json_ref",
        "validation_report_ref"
      ],
      "next": [
        "J3_exit"
      ]
    },
    {
      "id": "J3_exit",
      "phase": "JSON_TOOL",
      "action": "emit_json_tool_outputs",
      "outputs": [],
      "next": []
    }
  ],
  "invariants": [
    "json_schema_is_canonical_authority",
    "bundled_execution_surface_is_validation_first",
    "validated_inputs_exit_without_forced_derive"
  ]
}
