  "operators": [
    {
      "id": "extract",
      "purpose": "Normalize unstructured external input into a candidate JSON envelope.",
      "primary_engine": [
        "LLM"
      ],
      "optional_supporting_layers": [
        "CUE"
      ],
      "inputs": [
        "external_ds",
        "target_contract_ref"
      ],
      "outputs": [
        "candidate_envelope"
      ],
      "preconditions": [
        "Input is not already canonical JSON.",
        "Target contract is known."
      ],
      "notes": [
        "Extract does semantic lifting only.",
        "It does not accept or publish canonical artifacts by itself."
      ]
    },
    {
      "id": "unify",
      "purpose": "Constrain, complete, and merge candidates against contract-aligned constraints.",
      "primary_engine": [
        "CUE"
      ],
      "inputs": [
        "candidate_envelope or json_instance",
        "json_schema_contract or imported constraint set"
      ],
      "outputs": [
        "accepted_json or incompleteness_report"
      ],
      "preconditions": [
        "Target contract is aligned into the CUE constraint space when CUE is used."
      ],
      "notes": [
        "Unify is the incomplete-state and interlingua boundary.",
        "It does not replace downstream JSON Schema validation."
      ]
    },
    {
      "id": "validate",
      "purpose": "Validate accepted JSON against canonical contracts.",
      "primary_engine": [
        "JSON Schema"
      ],
      "inputs": [
