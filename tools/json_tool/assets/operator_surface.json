      ],
      "preconditions": [
        "Canonical schema exists."
      ],
      "notes": [
        "Validate is the canonical artifact gate.",
        "Failed validation stops derivation and authorization."
      ]
    },
    {
      "id": "derive",
      "purpose": "Project, reshape, and assemble downstream JSON artifacts.",
      "primary_engine": [
        "jq"
      ],
      "optional_supporting_layers": [
        "jaq"
      ],
      "inputs": [
        "accepted_json"
      ],
      "outputs": [
        "derived_artifacts"
      ],
      "preconditions": [
        "Input JSON is valid."
      ],
      "notes": [
        "Use jq as the default wrangling engine.",
        "Use jaq only when Rust-side embedding is required."
      ]
    },
    {
      "id": "check",
      "purpose": "Evaluate deterministic invariants and derive validation facts.",
      "primary_engine": [
        "CEL"
      ],
      "inputs": [
        "accepted_json or derived_artifacts"
      ],
      "outputs": [
        "validation_facts"
      ],
      "preconditions": [
        "Objects are already shaped and structurally valid."
      ],
      "notes": [
        "CEL is for predicates and computed selectors, not full document rewrites.",
        "Outputs are auditable evaluation evidence, not formal proof."
      ]
    },
    {
      "id": "authorize",
      "purpose": "Decide whether a requested transition or action is allowed.",
      "primary_engine": [
        "OPA/Rego"
      ],
      "inputs": [
        "state",
        "transition",
        "actor",
        "validation_facts"
