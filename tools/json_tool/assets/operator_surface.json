      ],
      "notes": [
        "OPA/Rego is the transition authorization layer.",
        "Authorization should consume facts rather than duplicate low-level invariant logic."
      ]
    },
    {
      "id": "render",
      "purpose": "Render human-facing or text payload outputs from accepted artifacts.",
      "primary_engine": [
        "MiniJinja"
