{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "polyrepo_workspace/schemas/change_lineage.schema.json",
  "title": "change_lineage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_family",
    "schema_version",
    "instance_authority",
    "workspace_id",
    "registry_id",
    "changes"
  ],
  "properties": {
    "artifact_family": {
      "const": "change_lineage"
    },
    "schema_version": {
      "const": "v1"
    },
    "instance_authority": {
      "const": "local_manifest"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^ws-[a-z0-9][a-z0-9_-]*$"
    },
    "registry_id": {
      "type": "string",
      "pattern": "^change-lineage\\.[a-z0-9_-]+$"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "change_id",
          "item_id",
          "title",
          "tracking_ids",
          "repo_ids",
          "status",
          "current_run_id"
        ],
        "properties": {
          "change_id": {
            "type": "string",
            "pattern": "^WC-[0-9]{8}-[0-9]{3}$"
          },
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "tracking_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "repo_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "active",
              "blocked",
              "completed"
            ]
          },
          "current_run_id": {
            "type": "string",
            "pattern": "^RUN-[0-9]{8}-[0-9]{3}$"
          }
        }
      }
    }
  }
}
