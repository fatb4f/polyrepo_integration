{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "polyrepo_workspace/schemas/commit_observations.schema.json",
  "title": "commit_observations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_family",
    "schema_version",
    "instance_authority",
    "workspace_id",
    "registry_id",
    "observations"
  ],
  "properties": {
    "artifact_family": {
      "const": "commit_observations"
    },
    "schema_version": {
      "const": "v1"
    },
    "instance_authority": {
      "const": "local_manifest"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^ws-[a-z0-9][a-z0-9_-]*$"
    },
    "registry_id": {
      "type": "string",
      "pattern": "^commit-observations\\.[a-z0-9_-]+$"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "observation_id",
          "change_id",
          "repo_id",
          "commit_oid",
          "patch_id",
          "branch",
          "base_ref",
          "observed_at",
          "status"
        ],
        "properties": {
          "observation_id": {
            "type": "string",
            "pattern": "^OBS-[0-9]{8}-[0-9]{3}$"
          },
          "change_id": {
            "type": "string",
            "pattern": "^WC-[0-9]{8}-[0-9]{3}$"
          },
          "repo_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "commit_oid": {
            "type": "string",
            "pattern": "^[a-f0-9]{7,40}$"
          },
          "patch_id": {
            "type": "string",
            "minLength": 1
          },
          "branch": {
            "type": "string",
            "minLength": 1
          },
          "base_ref": {
            "type": "string",
            "minLength": 1
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "current",
              "superseded",
              "invalidated"
            ]
          }
        }
      }
    }
  }
}
